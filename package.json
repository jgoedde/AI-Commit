        "tslib": "^2.6"
    },
    "devDependencies": {
        "@types/jest": "^29.5",
        "@types/node": "^20",
        "@typescript-eslint/eslint-plugin": "^7.6",
        "@typescript-eslint/parser": "^7.6",
        "eslint": "^8.56",
        "eslint-config-prettier": "^9.1",
        "eslint-plugin-jest": "^28.2",
